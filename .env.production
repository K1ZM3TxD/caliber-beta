# Caliber — Production environment
# Used when running `next build` / `next start` or deployed to production.
NEXT_PUBLIC_APP_URL=https://www.caliber-app.com
DATABASE_URL="file:./prisma/prod.db"

# NextAuth — MUST be set in production environment
AUTH_SECRET=""
AUTH_URL=https://www.caliber-app.com

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (magic link) — SMTP connection string
EMAIL_SERVER=""
EMAIL_FROM="Caliber <noreply@caliber-app.com>"

# OpenAI — required for resume tailoring and pattern synthesis
# MUST be set in production environment
OPENAI_API_KEY=""
# Optional: override the default model for tailor generation
# OPENAI_MODEL_TAILOR="gpt-4o-mini"
