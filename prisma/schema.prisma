// Caliber — Prisma schema (PostgreSQL via Neon / Vercel Postgres)
// Covers NextAuth models + pipeline persistence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth standard models ─────────────────────────────────

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String?         @unique
  emailVerified   DateTime?
  image           String?
  caliberSessionId String?        // Links to calibration session for durable persistence
  accounts        Account[]
  sessions        Session[]
  pipelineEntries PipelineEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Pipeline persistence ─────────────────────────────────────

model PipelineEntry {
  id        String   @id
  userId    String?
  sessionId String?
  jobTitle  String
  company   String
  jobUrl    String   @default("")
  score     Float    @default(0)
  stage     String   @default("strong_match")
  tailorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([userId, jobUrl])
}

// ─── Telemetry events (durable) ───────────────────────────────

model TelemetryEvent {
  id        String   @id @default(cuid())
  event     String
  timestamp DateTime @default(now())
  sessionId String?
  surfaceKey String?
  jobId     String?
  jobTitle  String?
  company   String?
  jobUrl    String?
  score     Float?
  source    String?
  scoreSource      String?
  signalPreference String?
  meta      String?  // JSON-encoded

  @@index([sessionId])
  @@index([event])
  @@index([sessionId, event])
}

// ─── Feedback events (durable) ────────────────────────────────

model FeedbackEvent {
  id                          String   @id @default(cuid())
  timestamp                   DateTime @default(now())
  surface                     String   // extension | calibration_results | title_suggestion
  site                        String?
  companyName                 String?
  jobTitle                    String?
  searchTitle                 String?
  calibrationTitleDirection   String?
  fitScore                    Float?
  decisionLabel               String?
  hiringRealityBand           String?
  betterSearchTitleSuggestion String?
  feedbackType                String   // thumbs_up | thumbs_down | bug_report
  feedbackReason              String?
  bugCategory                 String?
  optionalComment             String?
  // Behavioral signals (flattened)
  jobsViewedInSession              Int?
  scoresBelowSixCount              Int?
  highestScoreSeen                 Float?
  betterTitleSuggestionShown       Boolean @default(false)
  betterTitleSuggestionClicked     Boolean @default(false)

  @@index([surface])
  @@index([feedbackType])
  @@index([timestamp])
}
