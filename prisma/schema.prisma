// Caliber — Prisma schema (PostgreSQL via Neon / Vercel Postgres)
// Covers NextAuth models + pipeline persistence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth standard models ─────────────────────────────────

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String?         @unique
  emailVerified   DateTime?
  image           String?
  caliberSessionId String?        // Links to calibration session for durable persistence
  accounts        Account[]
  sessions        Session[]
  pipelineEntries PipelineEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Pipeline persistence ─────────────────────────────────────

model PipelineEntry {
  id        String   @id
  userId    String?
  sessionId String?
  jobTitle  String
  company   String
  jobUrl    String   @default("")
  score     Float    @default(0)
  stage     String   @default("strong_match")
  tailorId      String?
  tailoredText  String?  // Persisted tailored resume output (survives cold starts)
  jobText       String?  // Job description text for tailor context
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([userId, jobUrl])
}

// ─── Calibration sessions (durable) ───────────────────────────

model CalibrationSessionRecord {
  sessionId String   @id
  data      String   // Full session JSON blob
  locked    Boolean  @default(false) // personVector.locked — quick filter
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locked])
  @@index([updatedAt])
}

// ─── Telemetry events (durable) ───────────────────────────────

model TelemetryEvent {
  id        String   @id @default(cuid())
  event     String
  timestamp DateTime @default(now())
  userId    String?
  sessionId String?
  surfaceKey String?
  jobId     String?
  jobTitle  String?
  company   String?
  jobUrl    String?
  score     Float?
  source    String?
  scoreSource      String?
  signalPreference String?
  meta      String?  // JSON-encoded

  @@index([userId])
  @@index([sessionId])
  @@index([event])
  @@index([sessionId, event])
}

// ─── Canonical Job Record + Score Cache ───────────────────────
// Stores trusted job records and per-user/session score cache entries
// populated from current trusted scoring flows (sidecard, pipeline save).
// This is the foundation for future zero-click overlay lookup and homepage
// inventory. External acquisition paths are NOT implemented here.

model CanonicalJob {
  id            String   @id              // "cj_{hex16}"
  canonicalKey  String   @unique          // stable dedupe key: "linkedin:job:{id}" | "indeed:job:{jk}" | "url:{normalizedUrl}"
  platform      String                    // "linkedin" | "indeed" | "web"
  sourceUrl     String                    // original URL as first encountered
  title         String
  company       String
  location      String?
  jobText       String?                   // trusted full JD text (null until a full-text scoring event writes it)
  textWordCount Int?                      // word count of stored jobText (freshness/completeness signal)
  textSource    String?                   // "sidecard_full" | "pipeline_save" — provenance of stored text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scoreCaches   JobScoreCache[]

  @@index([platform])
  @@index([sourceUrl])
}

model JobScoreCache {
  id           String   @id              // "jsc_{hex16}"
  jobId        String                    // → CanonicalJob.id
  userId       String?                   // → User.id (null for unauthenticated session-only users)
  sessionId    String                    // caliber sessionId that produced the score
  score        Float                     // cached score_0_to_10
  scorePayload String                    // JSON: {supports_fit, stretch_factors, hrcBand, hrcReason, workModeCompat, roleType, calibrationTitle}
  scoringModel String   @default("v1")   // versioning hook — bump when scoring algorithm changes materially
  textSource   String                    // "sidecard_full" — provenance of the job text used for this score
  scoredAt     DateTime @default(now())

  job          CanonicalJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, sessionId])           // one latest cache per job+calibration session
  @@index([jobId])
  @@index([userId])
  @@index([sessionId])
}

// ─── Feedback events (durable) ────────────────────────────────

model FeedbackEvent {
  id                          String   @id @default(cuid())
  timestamp                   DateTime @default(now())
  userId                      String?
  surface                     String   // extension | calibration_results | title_suggestion
  site                        String?
  companyName                 String?
  jobTitle                    String?
  jobUrl                      String?  // job page URL at time of feedback — links to TelemetryEvent
  searchTitle                 String?
  surfaceKey                  String?  // matches TelemetryEvent.surfaceKey — enables surface-level joins
  sessionId                   String?  // matches TelemetryEvent.sessionId — enables session-level joins
  calibrationTitleDirection   String?
  fitScore                    Float?
  decisionLabel               String?
  hiringRealityBand           String?
  betterSearchTitleSuggestion String?
  feedbackType                String   // thumbs_up | thumbs_down | bug_report
  feedbackReason              String?
  bugCategory                 String?
  optionalComment             String?
  // Behavioral signals (flattened)
  jobsViewedInSession              Int?
  scoresBelowSixCount              Int?
  highestScoreSeen                 Float?
  betterTitleSuggestionShown       Boolean @default(false)
  betterTitleSuggestionClicked     Boolean @default(false)

  @@index([userId])
  @@index([surface])
  @@index([feedbackType])
  @@index([timestamp])
  @@index([surfaceKey])
  @@index([sessionId])
}
