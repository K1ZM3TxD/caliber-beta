# Caliber — Development environment
# Used when running `next dev` (localhost).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# DATABASE_URL — set to your Neon/Vercel Postgres connection string
# Example: postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgres://localhost:5432/caliber_dev"

# NextAuth
AUTH_SECRET="dev-secret-change-in-production"
AUTH_URL=http://localhost:3000

# Google OAuth — get credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (magic link) — SMTP connection string
# For dev testing with Ethereal: https://ethereal.email
# Format: smtp://user:pass@smtp.ethereal.email:587
EMAIL_SERVER=""
EMAIL_FROM="Caliber <noreply@caliber-app.com>"

# OpenAI — required for resume tailoring and pattern synthesis
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Optional: override the default model for tailor generation
# OPENAI_MODEL_TAILOR="gpt-4o-mini"
